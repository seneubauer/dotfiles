[general]
import = [
    "~/.config/alacritty/themes/noctalia.toml",
]

[window]
dynamic_title = true
padding.x = 10
padding.y = 10
opacity = 0.9

[font]
size = 11

[font.normal]
family = {{ .terminalfont | quote }}
style = "Regular"

[font.bold]
family = {{ .terminalfont | quote }}
style = "Bold"

[font.italic]
family = {{ .terminalfont | quote }}
style = "Italic"

[font.bold_italic]
family = {{ .terminalfont | quote }}
style = "Bold Italic"

[font.offset]
x = 0
y = 0
